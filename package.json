{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node -e \"if (!require('fs').existsSync('dist/server.cjs')) { console.log('dist/server.cjs not found, running build...'); try { require('child_process').execSync('bun run build', {stdio: 'inherit'}); } catch(e) { require('child_process').execSync('npm run build', {stdio: 'inherit'}); } }\" && node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^5.2.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.12",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "uuid": "^14.0.1",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.1",
    "@types/uuid": "^11.0.0",
    "autoprefixer": "^10.5.4",
    "tailwindcss": "^4.3.3"
  }
}
